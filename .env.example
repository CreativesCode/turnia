# Copiar a .env.local y rellenar con los valores de tu proyecto Supabase
# Dashboard: https://supabase.com/dashboard/project/<PROJECT_REF>/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://<TU_PROYECTO>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<TU_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>

# URL pública de la app (sin barra final). Se usa en dos lugares:
#   1. APP_URL se publica como secret en Supabase Edge Functions
#      (invite-user, resend-invitation, send-notification,
#      send-invitation-reminder) para construir los enlaces de los
#      emails de invitación. El script setup-edge-secrets.ps1 lee este
#      valor y lo sube al dashboard de Supabase.
#   2. NEXT_PUBLIC_APP_URL se expone al navegador para que el botón
#      "Copiar enlace" de InvitationsList use la URL canónica de
#      producción incluso cuando se prueba en localhost.
APP_URL=https://turnia-mu.vercel.app
NEXT_PUBLIC_APP_URL=https://turnia-mu.vercel.app
